# ------------------------------------------------------------
# Core
# ------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=DEBUG

MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=price-tracker
MONGO_DB_NAME=price_tracker
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# Security / Web
# ------------------------------------------------------------
COOKIE_SECURE=false
ALLOWED_ORIGINS=http://localhost:5173
SECRET_KEY=replace-with-a-long-random-secret
API_KEY=replace-with-random-api-key

LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900

# ------------------------------------------------------------
# Scheduler / Notifications
# ------------------------------------------------------------
# Valid values: cron | test | off
SCHEDULER_MODE=cron
SCHEDULER_TEST_DELAY_MINUTES=2
TARGET_REMINDER_HOURS=24

# Internal debug endpoints in Settings / API
INTERNAL_DEBUG_ENABLED=false
INTERNAL_DEBUG_REQUIRE_ADMIN=false

# ------------------------------------------------------------
# Telegram
# ------------------------------------------------------------
TELEGRAM_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# Email / SMTP
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=replace-with-app-password
SMTP_FROM_EMAIL=noreply@pricetracker.app
SMTP_FROM_NAME=PriceTracker
FEEDBACK_INBOX=feedback@pricetracker.app

# ------------------------------------------------------------
# Optional legacy flags (kept for compatibility)
# ------------------------------------------------------------
NOTIFICATION_ENABLED=true
PRICE_DROP_ALERT_ENABLED=true
WEEKLY_REMINDER_ENABLED=true
WEEKLY_REMINDER_DAY=monday
EMAIL_TEMPLATE_PRICE_DROP=price_alert
EMAIL_TEMPLATE_WEEKLY_SUMMARY=weekly_summary

# ------------------------------------------------------------
# Payment - Multi Provider (Stripe + Iyzico)
# ------------------------------------------------------------
PAYMENT_ENABLED=true
PAYMENT_PROVIDERS_ENABLED=stripe,iyzico
PAYMENT_DEFAULT_PROVIDER=stripe
PAYMENT_CURRENCY=USD
PAYMENT_PRICE_PRO_MONTHLY=2.99
PAYMENT_PRICE_PRO_YEARLY=29.99
FREE_MAX_TRACKED_ITEMS=5
FREE_TELEGRAM_ENABLED=false
PAYMENT_SUCCESS_URL=http://localhost:5173/payment/success
PAYMENT_CANCEL_URL=http://localhost:5173/payment/cancel
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=

# Iyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_CALLBACK_URL=http://localhost:8000/api/payments/callback/iyzico
IYZICO_WEBHOOK_SECRET=
IYZICO_SUBSCRIPTION_PLAN_PRO_MONTHLY=
IYZICO_SUBSCRIPTION_PLAN_PRO_YEARLY=
# Optional fallback redirect template if your Iyzico flow is hosted externally.
# Supported placeholders: {user_id}, {email}, {plan}, {interval}
IYZICO_CHECKOUT_URL_TEMPLATE=
